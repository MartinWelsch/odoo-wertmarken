<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
        Append one page per food ticket to the standard POS receipt.
        Each ticket starts a new page (page-break-before) so a single print job
        produces: page 1 = receipt, then one page per individual item bought.
    -->
    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt')]" position="inside">
            <t t-foreach="foodTickets" t-as="ticket" t-key="ticket_index">
                <div class="food-ticket"
                     style="page-break-before: always; text-align:center; padding-top:14px;">
                    <div style="border-top:2px dashed #000; margin-bottom:10px;"/>
                    <div style="font-size:16px; letter-spacing:2px;">Wertmarke</div>
                    <div style="font-size:30px; font-weight:bold; line-height:1.2; margin:10px 0;">
                        <t t-esc="ticket.productName"/>
                    </div>
                    <div style="border-top:1px dashed #000; margin:6px 0;"/>
                    <div t-if="props.data.name" style="font-size:12px;">
                        <t t-esc="props.data.name"/>
                    </div>
                    <div t-if="props.data.date" style="font-size:12px;">
                        <t t-esc="props.data.date"/>
                    </div>
                </div>
            </t>
        </xpath>
    </t>

</templates>
